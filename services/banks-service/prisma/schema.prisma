generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(uuid()) @db.Uuid
  phone        String   @unique
  email        String?  @unique
  passwordHash String?  @map("password_hash")
  isVerified   Boolean  @default(false) @map("is_verified")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  roles          UserRole[]
  profiles       Profile[]
  refreshTokens  RefreshToken[]
}

model Role {
  id          String   @id @default(uuid()) @db.Uuid
  name        String   @unique
  permissions Json     @default("[]")
  createdAt   DateTime @default(now()) @map("created_at")

  users UserRole[]
}

model UserRole {
  userId String @map("user_id") @db.Uuid
  roleId String @map("role_id") @db.Uuid
  user   User   @relation(fields: [userId], references: [id])
  role   Role   @relation(fields: [roleId], references: [id])

  @@id([userId, roleId])
  @@map("user_roles")
}

model Profile {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @unique @map("user_id") @db.Uuid
  fullName    String?  @map("full_name")
  avatarUrl   String?  @map("avatar_url")
  phone       String?
  email       String?
  dateOfBirth DateTime? @map("date_of_birth")
  gender      String?
  language    String   @default("ar")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id])
}

model RefreshToken {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")
  revokedAt DateTime? @map("revoked_at")

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([token])
  @@map("refresh_tokens")
}

model Governorate {
  id        String  @id @default(uuid()) @db.Uuid
  nameAr    String  @map("name_ar")
  nameEn    String  @map("name_en")
  code      String? @unique
  latitude   Decimal? @db.Decimal(10, 7)
  longitude Decimal? @db.Decimal(10, 7)
  isActive  Boolean @default(true) @map("is_active")

  cities City[]
}

model City {
  id             String @id @default(uuid()) @db.Uuid
  governorateId  String @map("governorate_id") @db.Uuid
  nameAr         String @map("name_ar")
  nameEn         String @map("name_en")
  latitude        Decimal? @db.Decimal(10, 7)
  longitude       Decimal? @db.Decimal(10, 7)

  governorate Governorate @relation(fields: [governorateId], references: [id])
  areas       Area[]
}

model Area {
  id         String  @id @default(uuid()) @db.Uuid
  cityId     String  @map("city_id") @db.Uuid
  nameAr     String  @map("name_ar")
  nameEn     String? @map("name_en")
  postalCode String? @map("postal_code")
  latitude   Decimal? @db.Decimal(10, 7)
  longitude  Decimal? @db.Decimal(10, 7)

  city City @relation(fields: [cityId], references: [id])
}

model SourceConfig {
  id              String   @id @default(uuid()) @db.Uuid
  domain          String
  sourceName      String   @map("source_name")
  sourceUrl       String   @map("source_url")
  sourceType      String   @default("api") @map("source_type")
  priority        Int      @default(5)
  updateFrequency String   @default("daily") @map("update_frequency")
  apiKey          String?  @map("api_key")
  headers         Json?    @default("{}")
  healthEndpoint  String?  @map("health_endpoint")
  paginationType  String?  @map("pagination_type")
  isActive        Boolean  @default(true) @map("is_active")
  lastSyncAt      DateTime? @map("last_sync_at")
  lastSyncStatus  String?  @default("never") @map("last_sync_status")
  consecutiveFailures Int  @default(0) @map("consecutive_failures")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  syncLogs ImportLog[]

  @@unique([domain, sourceName])
  @@index([domain])
  @@map("source_configs")
}

model ImportLog {
  id              String   @id @default(uuid()) @db.Uuid
  sourceConfigId  String   @map("source_config_id") @db.Uuid
  domain          String
  triggeredBy     String   @default("scheduled") @map("triggered_by")
  status          String   @default("running")
  recordsFetched  Int      @default(0) @map("records_fetched")
  recordsInserted Int      @default(0) @map("records_inserted")
  recordsUpdated  Int      @default(0) @map("records_updated")
  recordsFailed   Int      @default(0) @map("records_failed")
  recordsUnchanged Int     @default(0) @map("records_unchanged")
  errorMessage    String?  @map("error_message")
  durationMs      Int      @default(0) @map("duration_ms")
  startedAt       DateTime @default(now()) @map("started_at")
  completedAt     DateTime? @map("completed_at")
  createdAt       DateTime @default(now()) @map("created_at")

  sourceConfig SourceConfig @relation(fields: [sourceConfigId], references: [id])

  @@index([domain, createdAt(sort: Desc)])
  @@index([sourceConfigId, createdAt(sort: Desc)])
  @@index([status])
  @@map("import_logs")
}

model SyncRecord {
  id          String   @id @default(uuid()) @db.Uuid
  domain      String
  entityId    String   @map("entity_id") @db.Uuid
  entityType  String   @map("entity_type")
  importLogId String?  @map("import_log_id") @db.Uuid
  action      String   @default("insert")
  changedFields Json?  @map("changed_fields")
  sourceUrl   String?  @map("source_url")
  dataVersion Int      @default(1) @map("data_version")
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([domain, entityId])
  @@index([importLogId])
  @@index([createdAt(sort: Desc)])
  @@map("sync_records")
}

model Bank {
  id         String   @id @default(uuid()) @db.Uuid
  nameAr     String   @map("name_ar")
  nameEn     String?  @map("name_en")
  code       String   @unique
  logoUrl    String?  @map("logo_url")
  website    String?
  phone      String?
  email      String?
  isActive   Boolean  @default(true) @map("is_active")

  sourceName        String    @default("") @map("source_name")
  sourceUrl         String    @default("") @map("source_url")
  lastSyncAt        DateTime? @map("last_sync_at")
  lastVerifiedAt    DateTime? @map("last_verified_at")
  dataVersion       Int       @default(1) @map("data_version")
  validationStatus  String    @default("pending") @map("validation_status")

  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  branches BankBranch[]

  @@map("banks")
}

model BankBranch {
  id            String   @id @default(uuid()) @db.Uuid
  bankId        String   @map("bank_id") @db.Uuid
  nameAr        String   @map("name_ar")
  nameEn        String?  @map("name_en")
  branchCode    String?  @map("branch_code")
  governorateId String   @map("governorate_id") @db.Uuid
  cityId        String   @map("city_id") @db.Uuid
  areaId        String?  @map("area_id") @db.Uuid
  street        String?
  latitude      Decimal  @db.Decimal(10, 7)
  longitude     Decimal  @db.Decimal(10, 7)
  phone         String?
  hasAtm        Boolean  @default(false) @map("has_atm")
  isActive      Boolean  @default(true) @map("is_active")

  sourceName        String    @default("") @map("source_name")
  sourceUrl         String    @default("") @map("source_url")
  lastSyncAt        DateTime? @map("last_sync_at")
  lastVerifiedAt    DateTime? @map("last_verified_at")
  dataVersion       Int       @default(1) @map("data_version")
  validationStatus  String    @default("pending") @map("validation_status")

  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  bank         Bank              @relation(fields: [bankId], references: [id])
  workingHours BankWorkingHours[]
  services     BankBranchService[]

  @@index([latitude, longitude])
  @@map("bank_branches")
}

model BankWorkingHours {
  id         String  @id @default(uuid()) @db.Uuid
  branchId   String  @map("branch_id") @db.Uuid
  dayOfWeek  Int     @map("day_of_week")
  opensAt    String  @map("opens_at")
  closesAt   String  @map("closes_at")
  isClosed   Boolean @default(false) @map("is_closed")

  branch BankBranch @relation(fields: [branchId], references: [id])

  @@map("bank_working_hours")
}

model BankBranchService {
  id            String  @id @default(uuid()) @db.Uuid
  branchId      String  @map("branch_id") @db.Uuid
  serviceNameAr String  @map("service_name_ar")
  serviceNameEn String? @map("service_name_en")
  description   String?
  isAvailable   Boolean @default(true) @map("is_available")

  branch BankBranch @relation(fields: [branchId], references: [id])

  @@map("bank_branch_services")
}

model Pharmacy {
  id             String   @id @default(uuid()) @db.Uuid
  nameAr         String   @map("name_ar")
  nameEn         String?  @map("name_en")
  licenseNumber  String?  @unique @map("license_number")
  governorateId  String   @map("governorate_id") @db.Uuid
  cityId         String   @map("city_id") @db.Uuid
  areaId         String?  @map("area_id") @db.Uuid
  street         String?
  latitude       Decimal  @db.Decimal(10, 7)
  longitude      Decimal  @db.Decimal(10, 7)
  phone          String?
  whatsapp       String?
  is24h          Boolean  @default(false) @map("is_24h")
  hasDelivery    Boolean  @default(false) @map("has_delivery")
  isActive       Boolean  @default(true) @map("is_active")

  sourceName        String    @default("") @map("source_name")
  sourceUrl         String    @default("") @map("source_url")
  lastSyncAt        DateTime? @map("last_sync_at")
  lastVerifiedAt    DateTime? @map("last_verified_at")
  dataVersion       Int       @default(1) @map("data_version")
  validationStatus  String    @default("pending") @map("validation_status")

  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  workingHours PharmacyWorkingHours[]

  @@index([latitude, longitude])
  @@map("pharmacies")
}

model PharmacyWorkingHours {
  id         String  @id @default(uuid()) @db.Uuid
  pharmacyId String  @map("pharmacy_id") @db.Uuid
  dayOfWeek  Int     @map("day_of_week")
  opensAt    String? @map("opens_at")
  closesAt   String? @map("closes_at")
  isClosed   Boolean @default(false) @map("is_closed")
  is24h      Boolean @default(false) @map("is_24h")

  pharmacy Pharmacy @relation(fields: [pharmacyId], references: [id])

  @@map("pharmacy_working_hours")
}

model Hospital {
  id             String   @id @default(uuid()) @db.Uuid
  nameAr         String   @map("name_ar")
  nameEn         String?  @map("name_en")
  type           String   @default("hospital")
  ownership      String   @default("public")
  governorateId  String   @map("governorate_id") @db.Uuid
  cityId         String   @map("city_id") @db.Uuid
  areaId         String?  @map("area_id") @db.Uuid
  street         String?
  latitude       Decimal  @db.Decimal(10, 7)
  longitude      Decimal  @db.Decimal(10, 7)
  phone          String?
  email          String?
  website        String?
  hasEmergency   Boolean  @default(false) @map("has_emergency")
  bedCount       Int?     @map("bed_count")
  isActive       Boolean  @default(true) @map("is_active")

  sourceName        String    @default("") @map("source_name")
  sourceUrl         String    @default("") @map("source_url")
  lastSyncAt        DateTime? @map("last_sync_at")
  lastVerifiedAt    DateTime? @map("last_verified_at")
  dataVersion       Int       @default(1) @map("data_version")
  validationStatus  String    @default("pending") @map("validation_status")

  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  departments HospitalDepartment[]
  doctors     Doctor[]

  @@index([latitude, longitude])
  @@map("hospitals")
}

model HospitalDepartment {
  id         String   @id @default(uuid()) @db.Uuid
  hospitalId String   @map("hospital_id") @db.Uuid
  nameAr     String   @map("name_ar")
  nameEn     String?  @map("name_en")
  description String?
  floor      String?
  phone      String?

  hospital Hospital @relation(fields: [hospitalId], references: [id])
  doctors  Doctor[] @relation("doctorDepartment")

  @@map("hospital_departments")
}

model Doctor {
  id              String   @id @default(uuid()) @db.Uuid
  hospitalId      String   @map("hospital_id") @db.Uuid
  departmentId    String?  @map("department_id") @db.Uuid
  nameAr          String   @map("name_ar")
  nameEn          String?  @map("name_en")
  specialtyAr     String   @map("specialty_ar")
  specialtyEn     String?  @map("specialty_en")
  title           String?
  phone           String?
  email           String?
  consultationFee Decimal? @map("consultation_fee") @db.Decimal(10, 2)
  isActive        Boolean  @default(true) @map("is_active")

  hospital   Hospital            @relation(fields: [hospitalId], references: [id])
  department HospitalDepartment? @relation(fields: [departmentId], references: [id], name: "doctorDepartment")

  @@map("doctors")
}

model GovernmentOffice {
  id            String   @id @default(uuid()) @db.Uuid
  type          String   @default("other")
  nameAr        String   @map("name_ar")
  nameEn        String?  @map("name_en")
  officeCode    String?  @map("office_code")
  governorateId String   @map("governorate_id") @db.Uuid
  cityId        String   @map("city_id") @db.Uuid
  areaId        String?  @map("area_id") @db.Uuid
  street        String?
  latitude      Decimal  @db.Decimal(10, 7)
  longitude     Decimal  @db.Decimal(10, 7)
  phone         String?
  email         String?
  isActive      Boolean  @default(true) @map("is_active")

  sourceName        String    @default("") @map("source_name")
  sourceUrl         String    @default("") @map("source_url")
  lastSyncAt        DateTime? @map("last_sync_at")
  lastVerifiedAt    DateTime? @map("last_verified_at")
  dataVersion       Int       @default(1) @map("data_version")
  validationStatus  String    @default("pending") @map("validation_status")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  services GovernmentService[]

  @@index([latitude, longitude])
  @@map("government_offices")
}

model GovernmentService {
  id             String   @id @default(uuid()) @db.Uuid
  officeId       String   @map("office_id") @db.Uuid
  serviceNameAr  String   @map("service_name_ar")
  serviceNameEn  String?  @map("service_name_en")
  description    String?
  fee            Decimal? @db.Decimal(10, 2)
  processingTime String?  @map("processing_time")
  requiredDocs   Json?    @map("required_docs")
  isOnline       Boolean  @default(false) @map("is_online")
  isActive       Boolean  @default(true) @map("is_active")

  office GovernmentOffice @relation(fields: [officeId], references: [id])

  @@map("government_services")
}

model TransportStation {
  id               String   @id @default(uuid()) @db.Uuid
  type             String   @default("metro")
  nameAr           String   @map("name_ar")
  nameEn           String?  @map("name_en")
  code             String?
  lineName         String?  @map("line_name")
  governorateId    String   @map("governorate_id") @db.Uuid
  cityId           String   @map("city_id") @db.Uuid
  latitude         Decimal  @db.Decimal(10, 7)
  longitude        Decimal  @db.Decimal(10, 7)
  hasParking       Boolean  @default(false) @map("has_parking")
  hasAccessibility Boolean  @default(false) @map("has_accessibility")
  isActive         Boolean  @default(true) @map("is_active")

  sourceName        String    @default("") @map("source_name")
  sourceUrl         String    @default("") @map("source_url")
  lastSyncAt        DateTime? @map("last_sync_at")
  lastVerifiedAt    DateTime? @map("last_verified_at")
  dataVersion       Int       @default(1) @map("data_version")
  validationStatus  String    @default("pending") @map("validation_status")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  routesFrom TransportRoute[] @relation("fromStation")
  routesTo   TransportRoute[] @relation("toStation")

  @@index([latitude, longitude])
  @@map("transport_stations")
}

model TransportRoute {
  id            String   @id @default(uuid()) @db.Uuid
  type          String   @default("metro")
  nameAr        String   @map("name_ar")
  nameEn        String?  @map("name_en")
  fromStationId String   @map("from_station_id") @db.Uuid
  toStationId   String   @map("to_station_id") @db.Uuid
  distanceKm    Decimal? @map("distance_km") @db.Decimal(8, 2)
  durationMin   Int?     @map("duration_min")
  fare          Decimal? @db.Decimal(8, 2)
  isActive      Boolean  @default(true) @map("is_active")

  fromStation TransportStation @relation("fromStation", fields: [fromStationId], references: [id])
  toStation   TransportStation @relation("toStation", fields: [toStationId], references: [id])

  @@map("transport_routes")
}

model EmergencyContact {
  id             String   @id @default(uuid()) @db.Uuid
  type           String   @default("police")
  nameAr         String   @map("name_ar")
  nameEn         String?  @map("name_en")
  hotline        String
  alternatePhone String?  @map("alternate_phone")
  governorateId  String?  @map("governorate_id") @db.Uuid
  cityId         String?  @map("city_id") @db.Uuid
  latitude       Decimal? @db.Decimal(10, 7)
  longitude      Decimal? @db.Decimal(10, 7)
  isNational     Boolean  @default(false) @map("is_national")
  isActive       Boolean  @default(true) @map("is_active")

  sourceName        String    @default("") @map("source_name")
  sourceUrl         String    @default("") @map("source_url")
  lastSyncAt        DateTime? @map("last_sync_at")
  lastVerifiedAt    DateTime? @map("last_verified_at")
  dataVersion       Int       @default(1) @map("data_version")
  validationStatus  String    @default("pending") @map("validation_status")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([latitude, longitude])
  @@map("emergency_contacts")
}

model EmergencyAlert {
  id            String   @id @default(uuid()) @db.Uuid
  titleAr       String   @map("title_ar")
  titleEn       String?  @map("title_en")
  description   String
  severity      String   @default("info")
  affectedAreas Json     @map("affected_areas")
  isActive      Boolean  @default(true) @map("is_active")
  expiresAt     DateTime? @map("expires_at")

  sourceName        String    @default("") @map("source_name")
  sourceUrl         String    @default("") @map("source_url")
  lastSyncAt        DateTime? @map("last_sync_at")
  lastVerifiedAt    DateTime? @map("last_verified_at")
  dataVersion       Int       @default(1) @map("data_version")
  validationStatus  String    @default("pending") @map("validation_status")

  createdAt DateTime @default(now()) @map("created_at")

  @@map("emergency_alerts")
}

model SearchLog {
  id             String   @id @default(uuid()) @db.Uuid
  query          String
  type           String?
  governorateId  String?  @map("governorate_id") @db.Uuid
  resultCount    Int      @default(0) @map("result_count")
  userId         String?  @map("user_id") @db.Uuid
  ip             String?
  searchedAt     DateTime @default(now()) @map("searched_at")

  @@index([searchedAt(sort: Desc)])
  @@index([query])
  @@map("search_logs")
}

model Review {
  id             String   @id @default(uuid()) @db.Uuid
  userId         String   @map("user_id") @db.Uuid
  entityType     String   @map("entity_type")
  entityId       String   @map("entity_id") @db.Uuid
  rating         Int      @default(5)
  title         String?
  comment       String?
  isVerifiedPurchase Boolean @default(false) @map("is_verified_purchase")
  isApproved     Boolean  @default(false) @map("is_approved")
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  photos ReviewPhoto[]

  @@unique([userId, entityType, entityId])
  @@index([entityType, entityId])
  @@index([userId])
  @@index([entityType, entityId, rating])
  @@map("reviews")
}

model ReviewPhoto {
  id        String   @id @default(uuid()) @db.Uuid
  reviewId  String   @map("review_id") @db.Uuid
  url       String
  caption   String?
  sortOrder Int      @default(0) @map("sort_order")

  review Review @relation(fields: [reviewId], references: [id])

  @@index([reviewId])
  @@map("review_photos")
}

model Notification {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  type       String   @default("info")
  channel    String   @default("in_app")
  title      String
  body       String?
  metadata   Json?
  isRead     Boolean  @default(false) @map("is_read")
  readAt     DateTime? @map("read_at")
  createdAt  DateTime @default(now()) @map("created_at")

  logs NotificationLog[]

  @@index([userId, createdAt(sort: Desc)])
  @@index([userId, isRead])
  @@map("notifications")
}

model NotificationLog {
  id             String   @id @default(uuid()) @db.Uuid
  notificationId String   @map("notification_id") @db.Uuid
  channel        String   @default("in_app")
  status         String   @default("pending")
  error          String?
  sentAt         DateTime? @map("sent_at")

  notification Notification @relation(fields: [notificationId], references: [id])

  @@index([notificationId])
  @@map("notification_logs")
}

model NotificationPreference {
  id        String  @id @default(uuid()) @db.Uuid
  userId    String  @unique @map("user_id") @db.Uuid
  push      Boolean @default(true)
  email     Boolean @default(false)
  sms       Boolean @default(false)
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("notification_preferences")
}