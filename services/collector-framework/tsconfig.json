{
  "compilerOptions": {
    "module": "commonjs",
    "declaration": true,
    "removeComments": true,
    "target": "ES2021",
    "sourceMap": true,
    "outDir": "./dist",
    "baseUrl": "./",
    "incremental": true,
    "skipLibCheck": true,
    "strict": true,
    "esModuleInterop": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "paths": {
      "@egypt/shared-types": ["../../packages/shared-types/src"],
      "@egypt/shared-schemas": ["../../packages/shared-schemas/src"],
      "@egypt/shared-utils": ["../../packages/shared-utils/src"]
    }
  }
}