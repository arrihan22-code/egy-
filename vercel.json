{
  "installCommand": "npx pnpm@9 install --no-frozen-lockfile",
  "services": {
    "web": {
      "root": "apps/web",
      "framework": "nextjs",
      "buildCommand": "npx nx run @egypt/web:build",
      "outputDirectory": ".next"
    }
  },
  "rewrites": [
    { "source": "/(.*)", "destination": { "type": "service", "service": "web" } }
  ]
}
