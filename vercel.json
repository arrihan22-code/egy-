{
  "services": {
    "web": {
      "root": "apps/web",
      "framework": "nextjs",
      "installCommand": "cd ../.. && npx pnpm@9 install --no-frozen-lockfile && cd -",
      "buildCommand": "npx nx run @egypt/web:build",
      "outputDirectory": ".next"
    }
  },
  "rewrites": [
    { "source": "/(.*)", "destination": { "type": "service", "service": "web" } }
  ]
}
