{
  "services": {
    "web": {
      "root": "apps/web",
      "framework": "nextjs",
      "installCommand": "npx pnpm@11.9.0 install --no-frozen-lockfile",
      "buildCommand": "npx nx run @egypt/web:build",
      "outputDirectory": ".next"
    },
    "analytics-service": {
      "root": "services/analytics-service",
      "entrypoint": "src/main.ts"
    },
    "api-gateway": {
      "root": "services/api-gateway",
      "entrypoint": "src/main.ts"
    },
    "auth-service": {
      "root": "services/auth-service",
      "entrypoint": "src/main.ts"
    },
    "banks-service": {
      "root": "services/banks-service",
      "entrypoint": "src/main.ts"
    },
    "emergency-service": {
      "root": "services/emergency-service",
      "entrypoint": "src/main.ts"
    },
    "government-service": {
      "root": "services/government-service",
      "entrypoint": "src/main.ts"
    },
    "hospitals-service": {
      "root": "services/hospitals-service",
      "entrypoint": "src/main.ts"
    },
    "maps-service": {
      "root": "services/maps-service",
      "entrypoint": "src/main.ts"
    },
    "notifications-service": {
      "root": "services/notifications-service",
      "entrypoint": "src/main.ts"
    },
    "pharmacies-service": {
      "root": "services/pharmacies-service",
      "entrypoint": "src/main.ts"
    },
    "reviews-service": {
      "root": "services/reviews-service",
      "entrypoint": "src/main.ts"
    },
    "search-service": {
      "root": "services/search-service",
      "entrypoint": "src/main.ts"
    },
    "transport-service": {
      "root": "services/transport-service",
      "entrypoint": "src/main.ts"
    }
  },
  "rewrites": [
    {
      "source": "/api/notifications-service(/.*)?",
      "destination": {
        "type": "service",
        "service": "notifications-service"
      }
    },
    {
      "source": "/api/government-service(/.*)?",
      "destination": {
        "type": "service",
        "service": "government-service"
      }
    },
    {
      "source": "/api/pharmacies-service(/.*)?",
      "destination": {
        "type": "service",
        "service": "pharmacies-service"
      }
    },
    {
      "source": "/api/analytics-service(/.*)?",
      "destination": {
        "type": "service",
        "service": "analytics-service"
      }
    },
    {
      "source": "/api/emergency-service(/.*)?",
      "destination": {
        "type": "service",
        "service": "emergency-service"
      }
    },
    {
      "source": "/api/hospitals-service(/.*)?",
      "destination": {
        "type": "service",
        "service": "hospitals-service"
      }
    },
    {
      "source": "/api/transport-service(/.*)?",
      "destination": {
        "type": "service",
        "service": "transport-service"
      }
    },
    {
      "source": "/api/reviews-service(/.*)?",
      "destination": {
        "type": "service",
        "service": "reviews-service"
      }
    },
    {
      "source": "/api/search-service(/.*)?",
      "destination": {
        "type": "service",
        "service": "search-service"
      }
    },
    {
      "source": "/api/banks-service(/.*)?",
      "destination": {
        "type": "service",
        "service": "banks-service"
      }
    },
    {
      "source": "/api/auth-service(/.*)?",
      "destination": {
        "type": "service",
        "service": "auth-service"
      }
    },
    {
      "source": "/api/maps-service(/.*)?",
      "destination": {
        "type": "service",
        "service": "maps-service"
      }
    },
    {
      "source": "/api/api-gateway(/.*)?",
      "destination": {
        "type": "service",
        "service": "api-gateway"
      }
    },
    {
      "source": "/(.*)",
      "destination": {
        "type": "service",
        "service": "web"
      }
    }
  ]
}
