{
  "name": "egypt-services-platform",
  "version": "1.0.0",
  "private": true,
  "description": "Egypt Services Platform - Automated Data Aggregation System",
  "scripts": {
    "build": "nx run-many --target=build --all",
    "test": "nx run-many --target=test --all",
    "lint": "nx run-many --target=lint --all",
    "typecheck": "nx run-many --target=typecheck --all",
    "format": "prettier --write \"**/*.ts\"",
    "docker:up": "docker compose -f infrastructure/docker/docker-compose.yml up -d",
    "docker:down": "docker compose -f infrastructure/docker/docker-compose.yml down",
    "seed": "npx ts-node scripts/seed.ts"
  },
  "devDependencies": {
    "@nx/js": "^20.0.0",
    "nx": "^20.0.0",
    "typescript": "^5.5.0",
    "prettier": "^3.3.0",
    "eslint": "^9.0.0",
    "@types/node": "^22.0.0",
    "ts-node": "^10.9.0"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}